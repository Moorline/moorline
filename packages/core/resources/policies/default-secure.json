{
  "profile": "default-secure@0.1",
  "network": {
    "mode": "allowlist",
    "allowlist": [
      "provider:*",
      "http://localhost*",
      "https://localhost*",
      "http://127.0.0.1*",
      "https://127.0.0.1*",
      "http://[::1]*",
      "https://[::1]*"
    ]
  },
  "denyUnknownCapabilities": true,
  "allowCapabilities": [
    "command.exec",
    "transport.message.send",
    "transport.action.register",
    "transport.resource.create",
    "transport.resource.update",
    "transport.resource.delete",
    "fs.read",
    "fs.write",
    "memory.read",
    "memory.write",
    "session.inspect",
    "session.create",
    "session.direct",
    "session.archive",
    "session.delete",
    "package.state.read",
    "package.state.write",
    "package.job.manage",
    "net.connect",
    "runtime.control",
    "sidecar.manage"
  ],
  "actorRules": [
    {
      "actorPrefix": "runtime:transport/",
      "allowCapabilities": [
        "transport.action.register",
        "transport.message.send",
        "transport.resource.update",
        "session.archive"
      ]
    },
    {
      "actorPrefix": "runtime:surface/",
      "allowCapabilities": ["transport.resource.create", "transport.resource.update", "transport.resource.delete"]
    },
    {
      "actorPrefix": "runtime:status",
      "allowCapabilities": ["transport.message.send"]
    },
    {
      "actorPrefix": "runtime:command-runner",
      "allowCapabilities": ["command.exec"]
    },
    {
      "actorPrefix": "runtime:lifecycle/",
      "allowCapabilities": ["memory.write", "session.archive", "transport.resource.update"]
    },
    {
      "actorPrefix": "runtime:package-job",
      "allowCapabilities": ["transport.message.send", "net.connect", "session.direct", "package.state.read", "package.state.write", "package.job.manage"]
    },
    {
      "actorPrefix": "runtime:pending-request-action",
      "allowCapabilities": ["net.connect"]
    },
    {
      "actorPrefix": "runtime:provider/",
      "allowCapabilities": ["net.connect"]
    }
  ]
}
