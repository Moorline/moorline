{
  "id": "official/http",
  "name": "official/http",
  "version": "0.0.1",
  "type": "api-adapter",
  "description": "Official HTTP Control API adapter.",
  "entrypoint": "index.mjs",
  "displayCategory": "Official API Adapters",
  "activation": {
    "uniqueKey": "api-adapter"
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "host": {
        "type": "string",
        "title": "Host",
        "description": "HTTP bind host.",
        "default": "127.0.0.1"
      },
      "port": {
        "type": "number",
        "title": "Port",
        "description": "HTTP bind port.",
        "default": 45173
      },
      "exposure": {
        "type": "string",
        "title": "Exposure",
        "description": "Use loopback by default; remote is intended for reverse-proxy deployments.",
        "default": "loopback",
        "enum": ["loopback", "remote"]
      }
    }
  }
}
